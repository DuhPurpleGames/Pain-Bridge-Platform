{
  "version": 2,
  "functions": {
    "api/rhyme.js": {
      "runtime": "edge"
    },
    "api/notes.js": {
      "runtime": "edge"
    }
  },
  "routes": [
    {
      "src": "/api/rhyme",
      "dest": "/api/rhyme.js"
    },
    {
      "src": "/api/notes",
      "dest": "/api/notes.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
