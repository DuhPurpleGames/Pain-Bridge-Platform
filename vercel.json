{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/rhyme",
      "dest": "/api/rhyme.js"
    },
    {
      "src": "/api/notes",
      "dest": "/api/notes.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
